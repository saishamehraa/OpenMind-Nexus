# Backend Environment Variables
# Create this file in your backend directory

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/openmind?retryWrites=true&w=majority

# Server Configuration
PORT=3001
NODE_ENV=production

# OpenAI API Key (for AI bias detection)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative: Use Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-key

# Alternative: Use Google Gemini
# GOOGLE_API_KEY=your-google-api-key

# Multi-Agent Orchestration
VITE_BAND_API_KEY=your_band_api_key_here

# Frontend Config
VITE_API_URL=http://localhost:3001/api

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Secret (if using authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Optional: Redis for caching (if using)
# REDIS_URL=redis://localhost:6379

# Optional: Email service (for notifications)
# SENDGRID_API_KEY=your-sendgrid-key
# FROM_EMAIL=noreply@openmind.com

# Optional: Cloud storage (for user uploads)
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=openmind-uploads

# Optional: Monitoring
# SENTRY_DSN=your-sentry-dsn
